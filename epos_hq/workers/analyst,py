# --- Worker Loop ---

def work_loop():
    print(f"🧠 [ANALYST] Connected to {SIDECAR_URL}. Telemetry Active.")
    
    # Register with Bus
    bus.event(source="worker.start", worker_id=WORKER_ID, reason="Analyst online")

    while True:
        try:
            resp = httpx.post(f"{SIDECAR_URL}/mcp/request_task", json={"worker_id": WORKER_ID, "capabilities": CAPABILITIES}, timeout=5)
            
            if resp.status_code == 200:
                task = resp.json()
                if task.get("status") != "no_work":
                    
                    # 1. Log Receipt (+0.1 Process Reward)
                    print(f"⚡ [TASK] {task['type']}")
                    bus.emit(
                        reward_type="process", source="worker.received", score=0.1,
                        trace_id=task.get("trace_id"), worker_id=WORKER_ID,
                        task_type=task["type"], reason="Task picked up"
                    )

                    # Execute
                    try:
                        if task["type"] == "rules.synthesize":
                            res = synthesize_rules(task["run_id"])
                        elif task["type"] == "shadow.predict":
                            res = shadow_predict(task.get("inputs", {}).get("lead_id"), task["run_id"])
                        
                        # 2. Log Completion (+1.0 Outcome Reward)
                        bus.emit(
                            reward_type="outcome", source="worker.complete", score=1.0,
                            trace_id=task.get("trace_id"), worker_id=WORKER_ID,
                            task_type=task["type"], reason="Task executed successfully",
                            context={"result": str(res)}
                        )
                    except Exception as e:
                         # 3. Log Failure (-1.0 Process Reward)
                        bus.emit(
                            reward_type="process", source="worker.failed", score=-1.0,
                            trace_id=task.get("trace_id"), worker_id=WORKER_ID,
                            severity="error", reason=f"Crash: {e}"
                        )

            time.sleep(2)
        except Exception as e:
            print(f"⚠️ Error: {e}")
            time.sleep(5)

if __name__ == "__main__":
    work_loop()
