{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EPOS Mission Specification",
  "type": "object",
  "required": ["mission_id", "constitutional_authority", "tasks", "constraints", "success_criteria"],
  "properties": {
    "mission_id": { "type": "string" },
    "constitutional_authority": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "description"],
        "properties": {
          "task_id": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}