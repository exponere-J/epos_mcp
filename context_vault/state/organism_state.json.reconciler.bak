      "ttlg": {
        "scout": "Process Matrix Publisher. Inputs: organism_state.json + organism_inventory_scout.json. Outputs: organism_state.json process_matrix section (live). Dependencies: stdlib only (json, fcntl, os, ast, hashlib). Failure modes: probe errors \u2192 'unknown' status; lock contention \u2192 next interval; never crashes.",
        "thinker": "Realizes Article XVI \u00a71 mandate (proprioception). No overlap \u2014 first live publisher in the organism. Risks: registry corruption mitigated by atomic write + backup. Daemon mode + --once mode for cron flexibility.",
        "gate_reason": "AST OK; imports clean; functional test produces 197-component process_matrix in 0.66s; atomic write contract preserved.",
        "analyst_note": "Spec \u2194 actual match: 197 components \u2265 10 (acceptance criterion); status field populated for all; capability_tags mirrored from registry; connections derived from Scout inventory (443 edges).",
        "validated_at": "2026-04-23T10:52:57.956077+00:00",
        "validator": "Architect (inline)"
      },
      "utility_prose": "Publishes the live process_matrix section into organism_state.json every 5 minutes; satisfies Article XVI \u00a71.",
