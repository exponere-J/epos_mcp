{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EPOS Build Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "plan", "patch", "commands", "checks", "notes", "metadata"],
  "properties": {
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "summary", "confidence"],
      "properties": {
        "category": { "type": "string" },
        "summary": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "plan": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unified_diff"],
      "properties": {
        "unified_diff": { "type": "string" }
      }
    },
    "commands": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "notes": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd", "os_hint", "models", "created_at"],
      "properties": {
        "cwd": { "type": "string" },
        "os_hint": { "type": "string" },
        "models": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cadence", "metaphor", "critic"],
          "properties": {
            "cadence": { "type": "string" },
            "metaphor": { "type": "string" },
            "critic": { "type": "string" }
          }
        },
        "created_at": { "type": "string" }
      }
    }
  }
}
