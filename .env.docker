# =============================================================================
# EPOS SOVEREIGN STACK — Docker Environment
# Copy to .env.docker.local and fill in secrets before first launch:
#   cp .env.docker .env.docker.local
#   # edit .env.docker.local with real secrets
#   docker compose --env-file .env.docker.local up -d
#
# Required secrets (no defaults — must be set):
#   PG_PASSWORD      — PostgreSQL admin password
#   JWT_SECRET       — NocoDB JWT secret
#   N8N_ENCRYPTION_KEY — n8n workflow encryption key
# =============================================================================

# --- Required secrets (MUST be set before launch) ---
PG_PASSWORD=change_me_postgres_password
JWT_SECRET=change_me_jwt_secret_min_32_chars_xxxx
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key_32c

# --- LLM API keys ---
GROQ_API_KEY=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
LITELLM_MASTER_KEY=epos-litellm-key

# --- Ports (override defaults if needed) ---
PG_PORT=5433
OLLAMA_PORT=11434
LITELLM_PORT=4000
EPOS_API_PORT=8001
FRIDAY_PORT=8090
GOVERNANCE_GATE_PORT=8101
GOVERNANCE_SRV_PORT=8108
CONTEXT_SERVER_PORT=8103
IMMUNE_MONITOR_PORT=8104
LEARNING_SERVER_PORT=8102
AZ_PORT=50080
NOCODB_PORT=8080
N8N_PORT=5678

# --- Context vault path (absolute host path to context_vault dir) ---
CONTEXT_VAULT_PATH=./context_vault

# --- NocoDB ---
NOCODB_API_TOKEN=
NOCODB_PUBLIC_URL=http://localhost:8080

# --- n8n ---
N8N_WEBHOOK_URL=http://localhost:5678/

# --- LLM routing ---
LLM_MODE=groq_direct
OLLAMA_MODEL=phi3:mini

# --- Database ---
PG_USER=epos_admin

# --- Timezone ---
TZ=America/New_York
OPENROUTER_API_KEY=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
