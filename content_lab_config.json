      "api_key_env": "ELEVENLABS_API_KEY",
      "echoes_voice_id_env": "ELEVENLABS_ECHOES_VOICE_ID",
      "epos_voice_id_env": "ELEVENLABS_EPOS_VOICE_ID"
    },
    "video": {
      "provider": "heygen",
      "api_key_env": "HEYGEN_API_KEY",
      "scenes": {
        "founder_glow": "",
        "schematic": "",
        "glitch": ""
      }
    },
    "graphics": {
      "provider": "canva",
      "api_key_env": "CANVA_API_KEY",
      "templates": {
        "thumbnail_founder_glow": "",
        "thumbnail_schematic": "",
        "thumbnail_glitch": "",
        "channel_banner": "",
        "carousel_slide": "",
        "lead_magnet_cover": ""
      }
    },
    "transcription": {
      "provider": "whisper_local",
      "model": "base",
      "fallback": "whisper_api"
    }
  },

  "production_rules": {
    "max_short_duration_s": 60,
    "min_short_duration_s": 15,
    "stabilization_window_hours": 24,
    "max_derivatives_per_source": 14,
    "affiliate_disclosure_required": true,
    "brand_validation_required": true
